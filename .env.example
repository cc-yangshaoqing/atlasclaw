# AtlasClaw Environment Configuration
# Copy this file to .env and fill in your values

# LLM Provider Configuration (Generic)
LLM_MODEL=deepseek/deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your-api-key-here
LLM_TEMPERATURE=0.2

# Doubao / Volcengine Ark Token Pool

# Token 1
TOKEN_1_PROVIDER=doubao
TOKEN_1_MODEL=doubao-seed-2-0-pro-260215
TOKEN_1_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
TOKEN_1_API_KEY=your-token-1-api-key-here

# Token 2
TOKEN_2_PROVIDER=doubao
TOKEN_2_MODEL=glm-4-7-251222
TOKEN_2_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
TOKEN_2_API_KEY=your-token-2-api-key-here

# Token 3
TOKEN_3_PROVIDER=doubao
TOKEN_3_MODEL=deepseek-v3-2-251201
TOKEN_3_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
TOKEN_3_API_KEY=your-token-3-api-key-here

# Jira Configuration
JIRA_USERNAME=admin
JIRA_PASSWORD=your-jira-password-here
JIRA_TOKEN=your-jira-token-here

# SmartCMP Configuration
CMP_URL=https://your-smartcmp-instance.com/
CMP_COOKIE=your-cookie-here

# CloudChef SmartCMP Agent SK
ATLASCLAW_WEBHOOK_SK_SMARTCMP_PREAPPROVAL=sk-for-smartcmp-preapproval-token

# OIDC / Keycloak SSO
# AUTH_PROVIDER: 'local' for username/password, 'oidc' for Keycloak/standard OIDC, 
# 'dingtalk_oidc' for DingTalk SSO, 'none' for anonymous mode
AUTH_PROVIDER=local
ATLASCLAW_JWT_SECRET=change-me-to-a-secure-secret-key
OIDC_ISSUER=http://<keycloak-host>:<port>/realms/<realm>
OIDC_CLIENT_ID=atlasclaw
OIDC_CLIENT_SECRET=your-oidc-client-secret-here
OIDC_REDIRECT_URI=http://localhost:8000/api/auth/callback

# DingTalk OA Approval Provider
DINGTALK_APP_KEY=your_app_key_here
DINGTALK_APP_SECRET=your_app_secret_here
DINGTALK_AGENT_ID=your_agent_id_here

# DingTalk Enterprise OIDC (Direct OAuth2 - no IDaaS required)
# Issuer defaults to https://login.dingtalk.com if not specified
# Get credentials from DingTalk Open Platform: https://open.dingtalk.com/
DINGTALK_OIDC_ISSUER=https://login.dingtalk.com
DINGTALK_OIDC_CLIENT_ID=your_dingtalk_oidc_client_id
DINGTALK_OIDC_CLIENT_SECRET=your_dingtalk_oidc_client_secret
DINGTALK_OIDC_REDIRECT_URI=https://your-atlasclaw.example.com/api/auth/callback
DINGTALK_CORP_ID=your_corp_id

# DingTalk OIDC Endpoints (default values for DingTalk official endpoints)
DINGTALK_OIDC_AUTH_ENDPOINT=https://login.dingtalk.com/oauth2/auth
DINGTALK_OIDC_TOKEN_ENDPOINT=https://api.dingtalk.com/v1.0/oauth2/userAccessToken
DINGTALK_OIDC_USERINFO_ENDPOINT=https://api.dingtalk.com/v1.0/contact/users/me
