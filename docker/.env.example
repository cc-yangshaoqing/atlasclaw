# AtlasClaw Docker Environment Configuration
# Copy this file to .env and update values for your deployment

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_NAME=atlasclaw
DB_USER=atlasclaw
DB_PASSWORD=atlasclaw_secret

# MySQL Root Password (for initialization)
MYSQL_ROOT_PASSWORD=root_secret

# Encryption Key for API Keys
# Generate a secure random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
ATLASCLAW_ENCRYPTION_KEY=change-me-in-production

# Optional: External API Keys (if using environment variables)
# DEEPSEEK_API_KEY=your-deepseek-api-key
# OPENAI_API_KEY=your-openai-api-key
