# ==============================================================
# GitHub Self-Hosted Runner environment template
# Copy this file to .env and fill required values.
# ==============================================================

# ------------------------------
# Required: Runner scope target
# ------------------------------
# repo | org | enterprise
RUNNER_SCOPE=repo

# For repo scope (required when RUNNER_SCOPE=repo)
REPO_URL=https://github.com/your-org/your-repo

# For org scope (required when RUNNER_SCOPE=org)
ORG_NAME=

# For enterprise scope (required when RUNNER_SCOPE=enterprise)
ENTERPRISE_NAME=

# ------------------------------
# Required: Authentication (choose one)
# ------------------------------
# Option A: Repository registration token (recommended for repo scope)
RUNNER_TOKEN=

# Option B: Personal Access Token (PAT), required for org/enterprise auto-registration
# Typical scopes: repo, admin:org, admin:enterprise, workflow, notifications
ACCESS_TOKEN=

# ------------------------------
# Optional: Runner identity & behavior
# ------------------------------
RUNNER_NAME=atlasclaw-runner
RUNNER_NAME_PREFIX=runner
RUNNER_GROUP=Default
LABELS=self-hosted,linux,x64,docker
NO_DEFAULT_LABELS=false
RUNNER_WORKDIR=/tmp/github-runner-workdir
CONFIGURED_ACTIONS_RUNNER_FILES_DIR=/runner/data

# true/false: run as root user inside container
RUN_AS_ROOT=true

# true/false: remove runner registration after each job
EPHEMERAL=false

# true/false: disable runner auto update
DISABLE_AUTO_UPDATE=false

# true/false: prevent config environment variables leaking into jobs
UNSET_CONFIG_VARS=true

# ------------------------------
# Optional: Runtime settings
# ------------------------------
GITHUB_HOST=github.com
START_DOCKER_SERVICE=false
TZ=Asia/Shanghai

# Diagnostics
DEBUG_ONLY=false
DEBUG_OUTPUT=false

# ------------------------------
# Optional: Docker Compose resource controls
# ------------------------------
CPU_LIMIT=2
MEMORY_LIMIT=4g
MEMORY_RESERVATION=2g

# Docker log rotation
LOG_MAX_SIZE=100m
LOG_MAX_FILE=5
